# Server runtime
PORT=3010
JWT_SECRET=replace-with-a-long-random-secret

# Optional persistence
DB_HOST=localhost
DB_NAME=costudio
DB_USER=costudio_user
DB_PASS=replace-with-database-password

# OpenAI (server-side ONLY; never expose to browser)
OPENAI_API_KEY=sk-proj-your-key-here

# Production collaboration and Edge Functions
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Vite proxy target (used only at dev time; safe to commit)
VITE_API_URL=http://127.0.0.1:3010
